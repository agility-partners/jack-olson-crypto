# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.

# ---------------------------------------------------------------------------
# Required for the AI assistant (/assistant page, /api/chat route)
# ---------------------------------------------------------------------------
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the model used by /api/chat (default: gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

# ---------------------------------------------------------------------------
# Backend API URL (only needed when running the Next.js dev server locally,
# outside Docker).  Point at wherever the CryptoAPI is listening.
#
# If the API is running via Docker Compose on the default port:
#   NEXT_PUBLIC_API_URL=http://localhost:8081
#
# If running the .NET API directly on the host (dotnet run):
#   NEXT_PUBLIC_API_URL=http://localhost:5000
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8081
